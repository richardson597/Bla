        function closeDropdownMenu() {
            threeDotsDropdown.classList.remove('open');
            menuDismissOverlay.classList.remove('active');
        }
        menuDismissOverlay.onclick = closeDropdownMenu;

        menuSettingsBtn.onclick = () => {
            closeDropdownMenu();
            listScreen.classList.remove('active');
            settingsScreen.classList.add('active');
        };
        settingsBackBtn.onclick = () => {
            settingsScreen.classList.remove('active');
            listScreen.classList.add('active');
        };

        // ==================== COMPREHENSIVE SEARCH PLATFORM SYSTEM ====================
        searchTriggerIcon.onclick = () => {
            closeDropdownMenu();
            listScreen.classList.remove('active');
            searchScreen.classList.add('active');
            mainSearchInput.value = '';
            searchResultsBox.innerHTML = '';
            renderSearchHistory();
        };
        searchCloseBtn.onclick = () => {
            searchScreen.classList.remove('active');
            listScreen.classList.add('active');
        };

        mainSearchInput.oninput = () => {
            const query = mainSearchInput.value.toLowerCase().trim();
            searchResultsBox.innerHTML = '';

            if (!query) {
                renderSearchHistory();
                return;
            }

            // Hide history items layout while real-time typing returns matches
            historyCardBox.style.display = 'none';
            noHistoryState.style.display = 'none';

            const matchedThreads = dataStore.filter(convo => {
                const matchedSender = convo.sender.toLowerCase().includes(query);
                const matchedMsgText = convo.messages.some(m => m.text.toLowerCase().includes(query));
                return matchedSender || matchedMsgText;
            });

            if (matchedThreads.length === 0) {
                searchResultsBox.innerHTML = '<div style="text-align:center; padding:20px; color:#7f7f7f;">No matches found</div>';
                return;
            }

            matchedThreads.forEach(convo => {
                const lastMsg = convo.messages[convo.messages.length - 1];
                const item = document.createElement('div');
                item.className = 'convo-item';
                item.onclick = () => {
                    searchScreen.classList.remove('active');
                    openChatThread(convo.id);
                };
                item.innerHTML = `
                    <div class="avatar" style="background-color: ${convo.avatarColor};">
                        ${convo.sender.charAt(0) === '+' ? '👤' : convo.sender.charAt(0).toUpperCase()}
                    </div>
                    <div class="convo-details">
                        <div class="convo-row-top"><span class="sender-name">${convo.sender}</span><span class="convo-time">${lastMsg.time}</span></div>
                        <div class="convo-row-bottom"><span class="short-msg">${lastMsg.text}</span></div>
                    </div>
                `;
                searchResultsBox.appendChild(item);
            });
        };

        function renderSearchHistory() {
            historyItemsContainer.innerHTML = '';
            if (searchHistory.length === 0) {
                historyCardBox.style.display = 'none';
                noHistoryState.style.display = 'flex';
                return;
            }
            historyCardBox.style.display = 'block';
            noHistoryState.style.display = 'none';

            searchHistory.forEach((item, index) => {
                const row = document.createElement('div');
                row.className = 'search-history-item';
                row.innerHTML = `
                    <span class="history-term" style="cursor:pointer;">${item.term}</span>
                    <div class="history-right">
                        <span class="history-date">${item.date}</span>
                        <button class="delete-history-btn" onclick="deleteHistoryElement(${index}, event)">×</button>
                    </div>
                `;
                row.querySelector('.history-term').onclick = () => {
                    mainSearchInput.value = item.term;
                    mainSearchInput.oninput();
                };
                historyItemsContainer.appendChild(row);
            });
        }

        window.deleteHistoryElement = (idx, event) => {
            event.stopPropagation();
            searchHistory.splice(idx, 1);
            localStorage.setItem(SEARCH_KEY, JSON.stringify(searchHistory));
            renderSearchHistory();
        };

        clearHistoryLink.onclick = () => {
            searchHistory = [];
            localStorage.setItem(SEARCH_KEY, JSON.stringify(searchHistory));
            renderSearchHistory();
        };

        micTriggerBtn.onclick = () => { voiceSearchModal.classList.add('active'); };
        micCloseShortcut.onclick = (e) => { e.stopPropagation(); voiceSearchModal.classList.remove('active'); };

        // ==================== COMPOSITION ENGINE LOGIC ====================
        newChatFab.onclick = () => {
            listScreen.classList.remove('active');
            composeScreen.classList.add('active');
            composeRecipientField.value = "";
            composeDummyInput.textContent = "Enter message";
            composeDummyInput.style.color = "#a6a6a6";
            activeInputFocus = 'recipient';
            composeRecipientField.style.borderBottom = "2px solid #2da1d7";
        };

        composeBackBtn.onclick = () => {
            composeScreen.classList.remove('active');
            listScreen.classList.add('active');
        };

        composeRecipientField.onclick = (e) => {
            e.stopPropagation();
            activeInputFocus = 'recipient';
            composeRecipientField.style.borderBottom = "2px solid #2da1d7";
        };

        composeDummyInput.onclick = (e) => {
            e.stopPropagation();
            activeInputFocus = 'body';
            composeRecipientField.style.borderBottom = "none";
            if (composeDummyInput.textContent === "Enter message") {
                composeDummyInput.textContent = "";
                composeDummyInput.style.color = "#000000";
            }
        };

        // KEYBOARD EVENT EMULATORS
        emulatedKeyboard.querySelectorAll('.key').forEach(keyNode => {
            keyNode.addEventListener('click', (e) => {
                e.stopPropagation();
                const keyId = keyNode.id;
                const valueText = keyNode.textContent.trim();

                if (keyId === 'key-shift') {
                    isShiftActive = !isShiftActive;
                    keyNode.style.background = isShiftActive ? '#ffffff' : '#adb4c4';
                    return;
                }

                if (keyId === 'key-backspace') {
                    if (activeInputFocus === 'recipient') {
                        composeRecipientField.value = composeRecipientField.value.slice(0, -1);
                    } else {
                        if (composeDummyInput.textContent !== "Enter message") {
                            composeDummyInput.textContent = composeDummyInput.textContent.slice(0, -1);
                            if (composeDummyInput.textContent === "") {
                                composeDummyInput.textContent = "Enter message";
                                composeDummyInput.style.color = "#a6a6a6";
                            }
                        }
                    }
                    return;
                }

                if (keyId === 'key-next') {
                    if (activeInputFocus === 'recipient') {
                        activeInputFocus = 'body';
                        composeRecipientField.style.borderBottom = "none";
                        if (composeDummyInput.textContent === "Enter message") {
                            composeDummyInput.textContent = "";
                            composeDummyInput.style.color = "#000000";
                        }
                    }
                    return;
                }

                let characterValue = valueText;
                if (keyNode.classList.contains('space-key')) characterValue = " ";
                
                if (!isNaN(characterValue) || characterValue === "," || characterValue === ".") {
                    // Constant non alphabetic bindings
                } else {
                    characterValue = isShiftActive ? characterValue.toUpperCase() : characterValue.toLowerCase();
                }

                if (activeInputFocus === 'recipient') {
                    composeRecipientField.value += characterValue;
                } else {
                    if (composeDummyInput.textContent === "Enter message") {
                        composeDummyInput.textContent = "";
                        composeDummyInput.style.color = "#000000";
                    }
                    composeDummyInput.textContent += characterValue;
                }

                if (isShiftActive && keyId !== 'key-shift') {
                    isShiftActive = false;
                    document.getElementById('key-shift').style.background = '#adb4c4';
                }
            });
        });

        document.getElementById('compose-send-trigger').onclick = () => {
            const targetRecipient = composeRecipientField.value.trim();
            const payloadMessage = composeDummyInput.textContent;

            if (!targetRecipient || payloadMessage === "Enter message" || !payloadMessage.trim()) return;

            const structuredConvoId = "convo-" + Date.now();
            const transientPackage = {
                id: structuredConvoId,
                sender: targetRecipient,
                avatarColor: "#2d9cdb",
                unread: 0,
                isShortCode: false,
                messages: [{ text: payloadMessage, time: "12:23 pm", date: "Sunday, 7 June 2026", isSent: true }]
            };

            dataStore.unshift(transientPackage);
            localStorage.setItem(STORAGE_KEY, JSON.stringify(dataStore));
            
            composeScreen.classList.remove('active');
            listScreen.classList.add('active');
            renderConversationsList();
        };

        // ==================== RENDERING & CONSOLE PROCESSING RUNTIMES ====================
        function renderConversationsList() {
            conversationsBox.innerHTML = '';
            let overallUnread = 0;
            dataStore.forEach(convo => {
                overallUnread += convo.unread;
                const lastMsg = convo.messages[convo.messages.length - 1];
                const item = document.createElement('div');
                item.className = 'convo-item';
                item.onclick = () => openChatThread(convo.id);
                item.innerHTML = `
                    <div class="avatar" style="background-color: ${convo.avatarColor};">
                        ${convo.sender.charAt(0) === '+' ? '👤' : convo.sender.charAt(0).toUpperCase()}
                    </div>
                    <div class="convo-details">
                        <div class="convo-row-top"><span class="sender-name">${convo.sender}</span><span class="convo-time">${lastMsg.time}</span></div>
                        <div class="convo-row-bottom"><span class="short-msg">${lastMsg.text}</span>${convo.unread > 0 ? `<span class="badge">${convo.unread}</span>` : ''}</div>
                    </div>
                `;
                conversationsBox.appendChild(item);
            });
            totalUnreadElement.textContent = `${overallUnread} unread messages`;
            navUnreadBadge.textContent = overallUnread;
            navUnreadBadge.style.display = overallUnread > 0 ? 'flex' : 'none';
        }

        function openChatThread(id) {
            closeDropdownMenu();
            activeChatId = id;
            const convo = dataStore.find(c => c.id === id);
            if (!convo) return;
            convo.unread = 0;
            localStorage.setItem(STORAGE_KEY, JSON.stringify(dataStore));
            chatScreenTitle.textContent = convo.sender;
            
            renderMessages(convo);
            renderDynamicFooter(convo);

            listScreen.classList.remove('active');
            chatScreen.classList.add('active');
        }

        function renderMessages(convo) {
            chatMessagesBox.innerHTML = '';
            let currentTrackedDate = "";

            convo.messages.forEach(msg => {
                if (msg.date && msg.date !== currentTrackedDate) {
                    currentTrackedDate = msg.date;
                    const dateTag = document.createElement('div');
                    dateTag.className = 'chat-date-indicator';
                    dateTag.textContent = currentTrackedDate;
                    chatMessagesBox.appendChild(dateTag);
                }

                const bubble = document.createElement('div');
                bubble.className = `msg-bubble ${msg.isSent ? 'sent' : 'received'}`;
                bubble.textContent = msg.text;
                chatMessagesBox.appendChild(bubble);

                const timeStamp = document.createElement('div');
                timeStamp.className = 'msg-time-stamp';
                timeStamp.textContent = msg.time;
                chatMessagesBox.appendChild(timeStamp);
            });
            chatMessagesBox.scrollTop = chatMessagesBox.scrollHeight;
        }

        function renderDynamicFooter(convo) {
            chatFooterWrapper.innerHTML = '';
            
            if (convo.isShortCode) {
                const disabledBar = document.createElement('div');
                disabledBar.className = 'no-reply-notice-bar';
                disabledBar.textContent = "Can't reply to this conversation";
                chatFooterWrapper.appendChild(disabledBar);
            } else {
                const activeForm = document.createElement('footer');
                activeForm.className = 'chat-input-area';
                activeForm.innerHTML = `
                    <form id="chat-form-interactive">
                        <input type="text" id="message-input" placeholder="Enter message..." autocomplete="off" required>
                        <button type="submit" id="send-btn">
                            <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M2,21L23,12L2,3V10L17,12L2,14V21Z"/></svg>
                        </button>
                    </form>
                `;
                chatFooterWrapper.appendChild(activeForm);

                document.getElementById('chat-form-interactive').onsubmit = (e) => {
                    e.preventDefault();
                    const inputElem = document.getElementById('message-input');
                    const textPayload = inputElem.value.trim();
                    if (!textPayload) return;

                    convo.messages.push({
                        text: textPayload,
                        time: "12:23 pm",
                        date: "Sunday, 7 June 2026",
                        isSent: true
                    });

                    localStorage.setItem(STORAGE_KEY, JSON.stringify(dataStore));
                    inputElem.value = "";
                    renderMessages(convo);
                };
            }
        }

        backBtn.onclick = () => { chatScreen.classList.remove('active'); listScreen.classList.add('active'); renderConversationsList(); };
        renderConversationsList();
    </script>
</body>
</html>
