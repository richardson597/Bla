<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Samsung One UI Messages Simulator</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }
        body {
            background: #000000;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        .app-container {
            width: 100%;
            max-width: 420px;
            height: 90vh;
            max-height: 850px;
            background: #ffffff;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 12px 40px rgba(0,0,0,0.6);
            border-radius: 32px;
            border: 4px solid #333333;
        }
        .screen {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #f7f7f9;
            display: none;
            flex-direction: column;
            z-index: 10;
        }
        .screen.active {
            display: flex;
        }

        /* ==================== MAIN CONVERSATIONS SCREEN ==================== */
        .main-header {
            background: #f7f7f9;
            padding: 16px 24px 8px 24px;
            display: flex;
            flex-direction: column;
            transition: all 0.3s ease;
            border-bottom: 1px solid transparent;
            z-index: 30;
        }
        .main-header.collapsed {
            padding: 12px 24px;
            background: #ffffff;
            border-bottom: 1px solid #f2f2f7;
        }
        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 40px;
        }
        .compact-title {
            font-size: 1.15rem;
            font-weight: 600;
            color: #000000;
            opacity: 0;
            transform: translateY(10px);
            transition: all 0.25s ease;
        }
        .main-header.collapsed .compact-title {
            opacity: 1;
            transform: translateY(0);
        }
        .header-actions {
            display: flex;
            gap: 20px;
            align-items: center;
        }
        .icon {
            width: 24px;
            height: 24px;
            fill: #000000;
            cursor: pointer;
        }
        .more-options-wrapper {
            position: relative;
            display: inline-block;
        }
        .orange-dot {
            position: absolute;
            top: 2px;
            right: 2px;
            width: 5px;
            height: 5px;
            background: #ec6533;
            border-radius: 50%;
        }
        .expandable-header-content {
            margin-top: 12px;
            transition: all 0.25s ease;
            max-height: 100px;
            opacity: 1;
            overflow: hidden;
        }
        .main-header.collapsed .expandable-header-content {
            max-height: 0;
            opacity: 0;
            margin-top: 0;
            pointer-events: none;
        }
        .main-title {
            font-size: 2.1rem;
            font-weight: 400;
            color: #000000;
        }
        .unread-count {
            font-size: 0.95rem;
            color: #ec6533;
            margin-top: 4px;
            font-weight: 500;
        }
        .tabs-container {
            display: flex;
            gap: 20px;
            margin-top: 16px;
        }
        .tab {
            background: none;
            border: none;
            font-size: 1.05rem;
            font-weight: 600;
            color: #7f7f7f;
            padding-bottom: 6px;
            cursor: pointer;
            position: relative;
        }
        .tab.active {
            color: #000000;
        }
        .tab.active::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: #000000;
            border-radius: 2px;
        }

        /* DROPDOWN MENU CONTEXT CARD */
        .dropdown-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 90;
            display: none;
        }
        .dropdown-overlay.active {
            display: block;
        }
        .more-menu-card {
            position: absolute;
            top: 50px;
            right: 16px;
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
            padding: 8px 0;
            width: 220px;
            display: flex;
            flex-direction: column;
            z-index: 100;
            transform: scale(0.85);
            opacity: 0;
            pointer-events: none;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            transform-origin: top right;
        }
        .more-menu-card.open {
            transform: scale(1);
            opacity: 1;
            pointer-events: auto;
        }
        .menu-item {
            background: none;
            border: none;
            width: 100%;
            text-align: left;
            padding: 12px 20px;
            font-size: 1rem;
            color: #000000;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .menu-item:active {
            background: #f2f2f7;
        }
        .menu-orange-badge {
            background: #ec6533;
            color: #ffffff;
            font-size: 0.75rem;
            font-weight: bold;
            padding: 2px 6px;
            border-radius: 10px;
        }

        /* SCROLLABLE VIEWPORTS */
        .tab-content-wrapper {
            flex: 1;
            position: relative;
            overflow: hidden;
        }
        .tab-panel {
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            overflow-y: auto;
            display: none;
            padding: 8px 16px 80px 16px;
        }
        .tab-panel.active {
            display: block;
        }
        .conversations-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .convo-item {
            background: #ffffff;
            border-radius: 20px;
            padding: 14px 16px;
            display: flex;
            align-items: center;
            gap: 14px;
            cursor: pointer;
            transition: background 0.2s;
        }
        .convo-item:active {
            background: #f2f2f7;
        }
        .avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ffffff;
            font-size: 1.2rem;
            font-weight: bold;
            flex-shrink: 0;
        }
        .convo-details {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 3px;
            overflow: hidden;
        }
        .convo-row-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .sender-name {
            font-weight: 600;
            color: #000000;
            font-size: 1.05rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .convo-time {
            font-size: 0.8rem;
            color: #7f7f7f;
        }
        .convo-row-bottom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
        }
        .short-msg {
            font-size: 0.92rem;
            color: #666666;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            flex: 1;
        }
        .badge {
            background: #ec6533;
            color: #ffffff;
            font-size: 0.75rem;
            font-weight: bold;
            min-width: 18px;
            height: 18px;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 5px;
        }

        /* CATEGORY AND CONTACTS INTERFACES */
        .category-panel {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 60%;
            text-align: center;
            padding: 24px;
        }
        .add-category-btn {
            background: #e1f3fa;
            color: #2da1d7;
            border: none;
            padding: 12px 24px;
            border-radius: 24px;
            font-size: 1rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            margin-bottom: 16px;
        }
        .category-instruction {
            font-size: 0.95rem;
            color: #7f7f7f;
            line-height: 1.4;
        }
        .contacts-body-panel {
            display: none;
            flex-direction: column;
            overflow-y: auto;
            height: 100%;
            padding: 8px 16px 80px 16px;
        }
        .contacts-body-panel.active {
            display: flex;
        }
        .contact-section-label {
            font-size: 0.85rem;
            color: #7f7f7f;
            font-weight: 600;
            margin: 14px 0 6px 4px;
        }
        .contact-card-row {
            background: #ffffff;
            padding: 12px 16px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 6px;
            cursor: pointer;
        }
        .contact-card-row:active {
            background: #f2f2f7;
        }
        .contact-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ffffff;
            font-weight: bold;
            font-size: 1.05rem;
        }
        .contact-name {
            font-size: 1rem;
            font-weight: 500;
            color: #000000;
        }
        .contacts-total-footer {
            text-align: center;
            color: #7f7f7f;
            font-size: 0.9rem;
            margin-top: 24px;
            padding-bottom: 20px;
        }

        /* FAB ACTION & BOTTOM NAVIGATION ELEMENT */
        .fab {
            position: absolute;
            bottom: 84px;
            right: 24px;
            width: 56px;
            height: 56px;
            background: #39b3e3;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 12px rgba(57,179,227,0.4);
            border: none;
            cursor: pointer;
            z-index: 40;
        }
        .bottom-nav {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 68px;
            background: #ffffff;
            border-top: 1px solid #f2f2f7;
            display: flex;
            z-index: 50;
        }
        .nav-item {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #7f7f7f;
            cursor: pointer;
            position: relative;
        }
        .nav-item.active {
            color: #39b3e3;
        }
        .nav-text {
            font-size: 0.95rem;
            font-weight: 500;
        }
        .nav-badge {
            position: absolute;
            top: 12px;
            right: 32px;
            background: #ec6533;
            color: #ffffff;
            font-size: 0.7rem;
            font-weight: bold;
            min-width: 16px;
            height: 16px;
            border-radius: 8px;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 0 4px;
        }
        .nav-active-line {
            position: absolute;
            bottom: 4px;
            width: 40px;
            height: 3px;
            background: #39b3e3;
            border-radius: 2px;
            display: none;
        }
        .nav-item.active .nav-active-line {
            display: block;
        }

        /* ==================== MESSAGES SETTINGS PANEL ==================== */
        .settings-header {
            background: #ffffff;
            padding: 16px;
            display: flex;
            align-items: center;
            gap: 16px;
            border-bottom: 1px solid #f2f2f7;
        }
        .back-button {
            background: none;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
        }
        .settings-title {
            font-size: 1.25rem;
            font-weight: bold;
            color: #000000;
        }
        .settings-body-scroll {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }
        .settings-card-group {
            background: #ffffff;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 2px 6px rgba(0,0,0,0.03);
        }
        .settings-row {
            width: 100%;
            background: none;
            border: none;
            padding: 16px 20px;
            text-align: left;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #f2f2f7;
            cursor: pointer;
        }
        .settings-row:last-child {
            border-bottom: none;
        }
        .settings-label {
            font-size: 1.02rem;
            color: #000000;
            font-weight: 500;
        }
        .settings-orange-dot {
            background: #ec6533;
            color: #ffffff;
            font-size: 0.7rem;
            font-weight: bold;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .oneui-switch {
            position: relative;
            display: inline-block;
            width: 46px;
            height: 26px;
        }
        .oneui-switch input { opacity: 0; width: 0; height: 0; }
        .switch-slider {
            position: absolute;
            cursor: pointer;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: #adb4c4;
            transition: .3s;
            border-radius: 34px;
        }
        .switch-slider:before {
            position: absolute;
            content: "";
            height: 20px;
            width: 20px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: .3s;
            border-radius: 50%;
        }
        input:checked + .switch-slider { background-color: #39b3e3; }
        input:checked + .switch-slider:before { transform: translateX(20px); }

        /* ==================== SEARCH TERMINAL PLATFORM ==================== */
        .search-top-bar {
            background: #ffffff;
            padding: 8px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid #f2f2f7;
        }
        .search-back-btn {
            background: none;
            border: none;
            cursor: pointer;
        }
        .search-input-wrapper {
            flex: 1;
            background: #f2f2f7;
            border-radius: 20px;
            padding: 6px 14px;
            display: flex;
            align-items: center;
        }
        .search-input-field {
            width: 100%;
            background: none;
            border: none;
            outline: none;
            font-size: 1rem;
            color: #000000;
        }
        .search-content-body {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
        }
        .recent-search-card {
            background: #ffffff;
            border-radius: 24px;
            padding: 16px;
            display: block;
        }
        .recent-search-title {
            font-size: 0.9rem;
            color: #7f7f7f;
            font-weight: bold;
            margin-bottom: 12px;
        }
        .search-history-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 4px;
            border-bottom: 1px solid #f9f9f9;
        }
        .search-history-item:last-child { border-bottom: none; }
        .history-term { font-size: 1rem; color: #000000; }
        .history-right { display: flex; align-items: center; gap: 12px; }
        .history-date { font-size: 0.8rem; color: #a6a6a6; }
        .delete-history-btn {
            background: none;
            border: none;
            color: #a6a6a6;
            font-size: 1.2rem;
            cursor: pointer;
        }
        .clear-all-history {
            width: 100%;
            background: none;
            border: none;
            color: #2da1d7;
            font-size: 0.95rem;
            font-weight: 600;
            text-align: center;
            margin-top: 14px;
            cursor: pointer;
        }
        .no-searches-box {
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 50%;
        }
        .no-searches-text { color: #7f7f7f; font-size: 1rem; }

        /* GOOGLE VOICE SEARCH MODAL SYSTEM */
        .voice-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.4);
            z-index: 200;
            display: none;
            flex-direction: column;
            justify-content: flex-end;
        }
        .voice-overlay.active { display: flex; }
        .voice-card {
            background: #ffffff;
            border-top-left-radius: 28px;
            border-top-right-radius: 28px;
            padding: 24px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .google-brand-text {
            font-size: 1.4rem;
            font-weight: 500;
            color: #4285f4;
            margin-bottom: 24px;
        }
        .mic-wave-container {
            position: relative;
            width: 80px; height: 80px;
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 20px;
        }
        .mic-pulse-bg {
            position: absolute;
            width: 100%; height: 100%;
            background: rgba(66, 133, 244, 0.15);
            border-radius: 50%;
            animation: pulse-wave 1.6s infinite ease-in-out;
        }
        @keyframes pulse-wave {
            0% { transform: scale(0.8); opacity: 0.5; }
            50% { transform: scale(1.2); opacity: 0.8; }
            100% { transform: scale(1.4); opacity: 0; }
        }
        .mic-active-blue {
            width: 56px; height: 56px;
            background: #4285f4;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            z-index: 10;
            cursor: pointer;
        }
        .voice-prompt-title { font-size: 1.15rem; color: #333333; font-weight: 500; margin-bottom: 6px;}
        .voice-locale-sub { font-size: 0.85rem; color: #7f7f7f; margin-bottom: 16px; }
        .speech-toast-disclaimer {
            background: #333333; color: #ffffff;
            font-size: 0.8rem; padding: 12px 16px;
            text-align: center; width: 100%;
        }

        /* ==================== INTERACTIVE ACTIVE CHAT THREAD ==================== */
        .chat-header {
            background: #ffffff;
            padding: 12px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #f2f2f7;
        }
        .chat-header-left { display: flex; align-items: center; gap: 12px; }
        .chat-header-info h2 { font-size: 1.15rem; color: #000000; font-weight: 600; }
        .chat-messages {
            flex: 1;
            background: #f2f2f7;
            padding: 16px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }
        .chat-date-indicator {
            align-self: center;
            background: #e5e5ea;
            color: #555555;
            font-size: 0.78rem;
            font-weight: 600;
            padding: 3px 12px;
            border-radius: 12px;
            margin: 12px 0;
            text-transform: uppercase;
        }
        .msg-bubble {
            max-width: 75%;
            padding: 10px 14px;
            font-size: 0.98rem;
            line-height: 1.4;
            margin-top: 6px;
            word-wrap: break-word;
        }
        .msg-bubble.received {
            background: #ffffff;
            color: #000000;
            align-self: flex-start;
            border-radius: 18px 18px 18px 4px;
        }
        .msg-bubble.sent {
            background: #39b3e3;
            color: #ffffff;
            align-self: flex-end;
            border-radius: 18px 18px 4px 18px;
        }
        .msg-time-stamp {
            font-size: 0.75rem;
            color: #999999;
            margin-top: 2px;
            margin-bottom: 4px;
        }
        .msg-bubble.received + .msg-time-stamp { align-self: flex-start; margin-left: 4px; }
        .msg-bubble.sent + .msg-time-stamp { align-self: flex-end; margin-right: 4px; }

        .no-reply-notice-bar {
            background: #e5e5ea;
            color: #666666;
            text-align: center;
            padding: 14px;
            font-size: 0.95rem;
            font-weight: 500;
        }
        .chat-input-area {
            background: #ffffff;
            padding: 8px 12px;
            border-top: 1px solid #f2f2f7;
        }
        #chat-form-interactive {
            display: flex;
            align-items: center;
            background: #f2f2f7;
            border-radius: 24px;
            padding: 4px 6px 4px 14px;
        }
        #message-input {
            flex: 1;
            background: none;
            border: none;
            outline: none;
            font-size: 1rem;
            padding: 6px 0;
        }
        #send-btn {
            background: #39b3e3;
            border: none;
            color: white;
            width: 36px; height: 36px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer;
        }

        /* ==================== NEW TEXT MESSAGE (COMPOSE) SCREEN ==================== */
        .compose-header {
            background: #ffffff;
            padding: 16px;
            display: flex;
            align-items: center;
            gap: 16px;
            border-bottom: 1px solid #f2f2f7;
        }
        .compose-header h2 { font-size: 1.2rem; color: #000000; }
        .recipient-area {
            background: #ffffff;
            padding: 12px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid #f2f2f7;
        }
        .recipient-label {
            font-size: 1rem;
            color: #7f7f7f;
            font-weight: 500;
        }
        .recipient-input {
            flex: 1;
            border: none;
            outline: none;
            font-size: 1.1rem;
            color: #000000;
        }
        .add-recipient-icon {
            width: 24px;
            height: 24px;
            background: #e5e5ea;
            border-radius: 50%;
            color: #7f7f7f;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
        }
        .compose-body {
            flex: 1;
            background: #ffffff;
        }
        .compose-bottom-bar {
            background: #ffffff;
            padding: 8px 16px;
            display: flex;
            align-items: center;
            gap: 16px;
            border-top: 1px solid #f2f2f7;
        }
        .media-actions {
            display: flex;
            gap: 14px;
            color: #7f7f7f;
        }
        .compose-input-box {
            flex: 1;
            background: #f2f2f7;
            border-radius: 24px;
            padding: 10px 16px;
            font-size: 1.05rem;
            color: #a6a6a6;
            cursor: pointer;
        }
        .compose-send-btn {
            background: none;
            border: none;
            color: #39b3e3;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* ==================== SAMSUNG HARDWARE VIRTUAL KEYBOARD ==================== */
        .samsung-keyboard {
            background: #d1d4dc;
            padding: 4px 2px 24px 2px;
            display: flex;
            flex-direction: column;
